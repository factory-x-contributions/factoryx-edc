meta {
  name: VaultSecret
  type: http
  seq: 4
}

post {
  url: {{VAULTURL}}/v1/{{VAULT_PATH}}/data/{{VAULT_PROVIDER_SECRET_PATH}}
  body: json
  auth: inherit
}

headers {
  X-Vault-Token: {{VAULT_TOKEN}}
}

body:json {
  {
    "data": {
      "content": "{{PROVIDER_STS_SECRET}}"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
