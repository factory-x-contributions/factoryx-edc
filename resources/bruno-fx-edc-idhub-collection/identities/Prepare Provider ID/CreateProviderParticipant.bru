meta {
  name: CreateProviderParticipant
  type: http
  seq: 1
}

post {
  url: {{PROVIDER_IDHUB_ID_API}}/v1alpha/participants
  body: json
  auth: inherit
}

headers {
  x-api-key: {{API_KEY}}
}

body:json {
  {
      "roles":[],
      "serviceEndpoints":[{
        "id": "ConsumerCredentialService-ID",
        "type": "CredentialService", 
        "serviceEndpoint": "{{PROVIDER_IDHUB_DID_API}}/api/credentials/v1/participants/{{DID_WEB_ID_PROVIDER_B64}}"
      }],
      "active": true,
      "participantId": "{{DID_WEB_ID_PROVIDER}}",
      "did": "{{DID_WEB_ID_PROVIDER}}",
      "key":{
          "keyId": "{{DID_WEB_ID_PROVIDER}}#key-1",
          "privateKeyAlias": "{{DID_WEB_ID_PROVIDER}}-alias",
          "keyGeneratorParams":{
              "algorithm": "EdDSA",
              "curve": "Ed25519"
          }
      }
  }
}

script:pre-request {
  bru.setEnvVar(
    "DID_WEB_ID_PROVIDER_B64",
    Buffer.from(
      bru.interpolate(bru.getEnvVar("DID_WEB_ID_PROVIDER")),
      "utf8"
    ).toString("base64")
  );
}

script:post-response {
  const apiKey = res.getBody().apiKey.trim();
  if (apiKey) {
    bru.setEnvVar("PROVIDER_IH_APIKEY", apiKey);
  }
  const stsSecret = res.getBody().clientSecret.trim();
  if (stsSecret) {
    bru.setEnvVar("PROVIDER_STS_SECRET", stsSecret)
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
